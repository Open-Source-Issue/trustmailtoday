# ----------------------------------------------------------------
# Trustmailtoday — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored by default in Next.js.
# ----------------------------------------------------------------

# Google OAuth 2.0 credentials
# Create them at: https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (type: Web application)
#   2. Add the redirect URI below to "Authorized redirect URIs"
#   3. Enable the "Gmail API" for the project
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Where Google sends the user back after consent.
# Must EXACTLY match an Authorized redirect URI in the Google console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Base URL of the app (used for post-login redirects)
APP_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------
# MongoDB (optional). If omitted, the app uses an in-memory store
# (state resets on restart — fine for local dev, not for production).
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net
# ----------------------------------------------------------------
MONGODB_URI=
MONGODB_DB=Trustmailtoday

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ----------------------------------------------------------------
# Razorpay subscriptions
# Dashboard: https://dashboard.razorpay.com/app/keys
#   1. Generate API keys (use Test mode first)
#   2. Create subscription Plans (Settings > Subscriptions/Plans) and paste
#      their plan_ids below. Amounts: Pro ₹200, Premium ₹500, Enterprise ₹2000
#   3. For webhooks: add an endpoint .../api/payment/webhook and set the secret
# ----------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Public key id is safe to expose to the browser (used by checkout.js).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Webhook signing secret (Razorpay dashboard > Webhooks).
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Razorpay Plan IDs for each paid tier.
RAZORPAY_PLAN_PRO=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_PREMIUM=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_ENTERPRISE=plan_xxxxxxxxxxxxx
