# ----------------------------------------------------------------
# Trustmailtoday — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored by default in Next.js.
# ----------------------------------------------------------------

# Google OAuth 2.0 credentials
# Create them at: https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (type: Web application)
#   2. Add the redirect URI below to "Authorized redirect URIs"
#   3. Enable the "Gmail API" for the project
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Where Google sends the user back after consent.
# Must EXACTLY match an Authorized redirect URI in the Google console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Base URL of the app (used for post-login redirects)
APP_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------
# MongoDB (optional). If omitted, the app uses an in-memory store
# (state resets on restart — fine for local dev, not for production).
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net
# ----------------------------------------------------------------
MONGODB_URI=
MONGODB_DB=Trustmailtoday

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ----------------------------------------------------------------
# Stripe subscriptions (single Stripe India account)
# Dashboard: https://dashboard.stripe.com/apikeys
#   1. Grab your API keys (use Test mode first).
#   2. Create one Product per tier with a recurring MONTHLY USD Price:
#        Pro $19, Premium $49, Enterprise $149. Paste the price_... ids below.
#   3. Enable payment methods (Cards + UPI) under Settings > Payment methods.
#      UPI is presented/settled in INR for India-located customers.
#   4. Enable the Customer Portal: Settings > Billing > Customer portal.
#   5. Add a webhook endpoint .../api/payment/webhook subscribed to:
#        checkout.session.completed, customer.subscription.created,
#        customer.subscription.updated, customer.subscription.deleted,
#        invoice.paid, invoice.payment_failed
#      then copy its signing secret into STRIPE_WEBHOOK_SECRET.
# ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Publishable key (only needed if you switch to client-side Elements; the
# current hosted-Checkout flow does not require it in the browser).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Webhook signing secret (Stripe dashboard > Developers > Webhooks, or the
# value printed by `stripe listen` during local development).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Recurring monthly USD Price ids for each paid tier.
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxx

# Free-trial length in days for paid plans (0 disables the trial). Default 7.
STRIPE_TRIAL_DAYS=7
